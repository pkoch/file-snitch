# Keep clangd aligned with the Zig build's C flags. Change the source of
# truth in build.zig first, then mirror any editor-needed fallback flags here.
If:
  PathMatch: c/.*
CompileFlags:
  Add:
    - -std=c11
    - -D_FILE_OFFSET_BITS=64
    - -I.
    - -isystem
    - /usr/local/include
    - -isystem
    - /opt/homebrew/include
    - -isystem
    - /usr/include/fuse3
---
If:
  PathMatch: c/.*\.h
CompileFlags:
  Remove:
    - -xobjective-c++-header
  Add:
    - -xc-header
