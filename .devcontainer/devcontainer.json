{
  "name": "File Snitch",
  "build": {
    "context": "..",
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--cap-add=SYS_ADMIN",
    "--device=/dev/fuse",
    "--security-opt=apparmor:unconfined"
  ],
  "remoteUser": "ubuntu",
  "customizations": {
    "vscode": {
      "extensions": ["ziglang.vscode-zig"]
    }
  }
}
