[Unit]
Description=File Snitch user daemon
Documentation=https://github.com/pkoch/file-snitch/blob/master/docs/services.md
After=default.target

[Service]
Type=simple
Environment=FILE_SNITCH_PASS_BIN={{PASS_BIN}}
ExecStart={{FILE_SNITCH_BIN}} run prompt
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
